{
    "type": "gameupdate",
    "payload": {
        "room": {
            "events": {
                "$array": {
                    "type": {"$enum": ["join", "newround", "gamestart", "pick", "gameover", "error"]},
                    "payload": {
                        "$slot": "any"
                    }
                }
            },
            "timeend": "uint",
            "timesec": "uint",
            "updated": "uint",
            "next_action": {
                "$enum": ["pick", "move", "select"]
            },
            "next_player": "int",
            "next_team": "int",
            "starttime": "uint",
            "endtime": "uint",
            "sequence": "uint",
            "status": "uint"
            
        },
        "teams": {
            "$static": {
                "team_slug": "string",
                "name": "string",
                "color": "string",
                "order": "uint",
                "players": {
                    "$static": "uint"
                },
                "rank": "uint",
                "score": "uint"
            }
        },
        "players": {
            "$static": {
                "id": "uint",
                "displayname": "string",
                "shortid": "string",
                "portraitid": "uint",
                "countrycode": "string",
                "rating": "uint",
                "teamid": "uint",
                "stats": {
                    "$map": {
                        "value": "uint"
                    }
                },
                "items": {
                    "$map": {
                        "name": "uint",
                        "balance": "uint"
                    }
                },
                "rank": "uint",
                "score": "uint"
            }
        },
        "state": {
            "$slot": "any"
        }
    }
}