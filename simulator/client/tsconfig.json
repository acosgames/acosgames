{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": false,
        "allowJs": false,
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "paths": {
            "@/*": ["./*"],
            "shared/*": ["../shared/*"],
            "acosgames": ["../../framework/src/index.ts"]
        }
    },
    "include": ["./**/*.ts", "./**/*.tsx", "../../framework/**/*.ts"],
    "exclude": ["node_modules", "webpack"]
}
